# =====================================================================
# conddo-payments backend — Render environment variables
# =====================================================================
# How to import:
#   1. Create a NEW Render web service named "Conddo-Payments"
#      pointing at this same GitHub repo (Mickercode/conddo-backend).
#   2. Set the Dockerfile path to `Dockerfile.payments`.
#   3. Set Region = Frankfurt (matches the other services).
#   4. Copy this file → infra/conddo-payments.env (gitignored)
#   5. Replace every <placeholder> with the real value
#   6. Render → Conddo-Payments service → Environment → "Add from .env"
#      (or use the bulk-edit / paste interface)
#   7. Paste the contents → Save → Render auto-restarts the service
#
# Placeholder markers:
#   <generate>       — pick any strong random value (Render has a Generate
#                      button on each row, or run: openssl rand -base64 48)
#   <copy-from-API>  — reuse the SAME value as on the conddo-backend service
#   <paste-yours>    — your secret / business value
# =====================================================================


# ---------------------------------------------------------------------
# DATABASE — same Postgres as conddo-backend. Payments owns the
# `payments` schema (Flyway creates it at boot). Values MUST match
# what conddo-backend uses for its owner role.
# ---------------------------------------------------------------------
PAYMENTS_DB_URL=<copy-from-API: CONDDO_DB_URL>
PAYMENTS_DB_USER=<copy-from-API: CONDDO_DB_OWNER>
PAYMENTS_DB_PASSWORD=<copy-from-API: CONDDO_DB_OWNER_PASSWORD>


# ---------------------------------------------------------------------
# PLATFORM → PAYMENTS HAND-OFF — the shared secret conddo-backend
# sends in X-Payments-Service-Token on /api/payments/internal/tenants.
# Generate ONCE here, then paste the SAME string into conddo-backend's
# env as PAYMENTS_SERVICE_TOKEN. Blank = internal surface disabled
# (every request 401s, signup → provisioning silently no-ops).
# ---------------------------------------------------------------------
PAYMENTS_SERVICE_TOKEN=<generate>


# ---------------------------------------------------------------------
# CONDDO-API CALLBACK — after a RoutePay webhook lands and we
# terminalise the local payment row, we POST to {CONDDO_API_BASE_URL}
# /api/v1/internal/payments/notify so the order/booking gets flipped
# to PAID and the in-app notification fires. Blank → callback is
# skipped (webhook still processed locally; reconciliation is manual).
# ---------------------------------------------------------------------
CONDDO_API_BASE_URL=https://conddo-backend.onrender.com


# ---------------------------------------------------------------------
# TENANT JWT VERIFICATION — same RSA public key as conddo-api so a
# tenant Bearer issued by conddo-api works here without re-login.
# Mount the key file alongside the runtime (volume / secret) and point
# this env var at it. Path format: file:/path/to/jwt_public.pem
# CONDDO_JWT_ISSUER is informational — leave blank to skip the issuer
# check (audience/sig checks always run).
# ---------------------------------------------------------------------
CONDDO_JWT_PUBLIC_KEY=<paste-yours: file:/etc/secrets/jwt_public.pem>
CONDDO_JWT_ISSUER=https://conddo.io


# ---------------------------------------------------------------------
# CORS — browser origins for the FE. Tenant-facing FE calls this
# service directly via NEXT_PUBLIC_PAYMENTS_API_URL. List Vercel
# preview URLs in the patterns var (wildcard format).
# Trailing slashes break the exact-match check; never include them.
# ---------------------------------------------------------------------
PAYMENTS_CORS_ALLOWED_ORIGINS=https://conddo-io.vercel.app
PAYMENTS_CORS_ALLOWED_ORIGIN_PATTERNS=https://conddo-io-*-mickercode.vercel.app


# ---------------------------------------------------------------------
# ROUTEPAY — sandbox credentials for the V1 launch. Get these from
# https://portalqa.routepay.com (test merchant dashboard). The webhook
# secret arrives separately when you configure the webhook endpoint
# (https://conddo-payments.onrender.com/api/payments/webhooks/routepay)
# inside that dashboard.
#
# Blank client-id → DormantRoutePayClient is on. Every charge attempt
# completes locally but never reaches RoutePay (deterministic stub
# URLs are returned so the FE flow still works for smoke tests).
# ---------------------------------------------------------------------
ROUTEPAY_AUTH_BASE_URL=https://auth-test.routepay.com
ROUTEPAY_BASE_URL=https://payment-test.routepay.com
ROUTEPAY_CLIENT_ID=<paste-yours: from RoutePay merchant dashboard>
ROUTEPAY_CLIENT_SECRET=<paste-yours: from RoutePay merchant dashboard>
ROUTEPAY_WEBHOOK_SECRET=<paste-yours: when you register the webhook URL>


# ---------------------------------------------------------------------
# CONDDO'S CUT — basis points (bps) from each successful payment
# routed via RoutePay's split-payment feature to the platform account.
# 250 = 2.50%. Adjust per plan tier if needed.
# ---------------------------------------------------------------------
# ROUTEPAY_PLATFORM_FEE_BPS=250


# =====================================================================
# AFTER you save the above on Conddo-Payments and get its public URL,
# add THESE TWO to the OTHER service (conddo-backend) → Environment.
# Without them the signup → payments sub-account provisioning stays
# dormant (TenantAccount row never appears in the payments schema).
# =====================================================================
#
# PAYMENTS_BASE_URL=https://conddo-payments.onrender.com
# PAYMENTS_SERVICE_TOKEN=<paste the same string you generated above>
