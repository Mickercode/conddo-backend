# =====================================================================
# conddo-studio — Render environment variables
# =====================================================================
# Copy this file → `infra/conddo-studio.env` (gitignored), fill in the real
# values, then on Render → conddo-studio service → Environment → "Add from .env"
# (or the bulk-paste field) and paste the contents.
#
# Markers in the placeholders:
#   <generate>     — let Render generate the value (it has a "Generate" button on
#                    the env-var row), then come back here and paste it.
#   <copy-from-API>— reuse the same value as on the conddo-backend service.
#   <paste-yours>  — your real secret/value.
# =====================================================================


# ---------------------------------------------------------------------
# DATABASE — same Postgres as conddo-backend; Studio creates its own
# `studio` and `jobs` schemas (Flyway runs as the owner role). All three
# values must match EXACTLY what conddo-backend already uses for Flyway,
# or Postgres returns "password authentication failed" / "permission denied
# to create schema". Don't guess the username — copy CONDDO_DB_OWNER from
# conddo-backend (it may not literally be "conddo_owner" — Render's
# auto-provisioned Postgres sometimes uses another name).
# ---------------------------------------------------------------------
STUDIO_DB_URL=<copy-from-API: CONDDO_DB_URL>
STUDIO_DB_USER=<copy-from-API: CONDDO_DB_OWNER>
STUDIO_DB_PASSWORD=<copy-from-API: CONDDO_DB_OWNER_PASSWORD>


# ---------------------------------------------------------------------
# STUDIO JWT — internal staff auth, completely separate from the
# platform's JWT. Secret ≥ 32 bytes.
# ---------------------------------------------------------------------
STUDIO_JWT_SECRET=<generate>
STUDIO_JWT_ISSUER=https://jobs.conddo.io


# ---------------------------------------------------------------------
# CORS — origin(s) the separate Next.js Studio frontend will call from.
# Comma-separate multiple. http://localhost:3000 is handy during dev.
# ---------------------------------------------------------------------
STUDIO_CORS_ALLOWED_ORIGINS=https://studio.conddo.io


# ---------------------------------------------------------------------
# PLATFORM → STUDIO JOB HAND-OFF — the shared secret conddo-backend
# sends in X-Studio-Service-Token on /api/jobs/intake. Generate ONCE here,
# then paste the SAME string into conddo-backend's env (see bottom of file).
# ---------------------------------------------------------------------
STUDIO_SERVICE_TOKEN=<generate>


# ---------------------------------------------------------------------
# FIRST-ADMIN BOOTSTRAP — Studio has no public staff signup, so this
# seeds the first ADMIN row when studio.staff is empty. After your first
# login, change the password in-app and CLEAR these three vars (Render →
# Edit → delete). The bootstrap is a no-op once any staff row exists.
# ---------------------------------------------------------------------
STUDIO_BOOTSTRAP_ADMIN_EMAIL=admin@conddo.io
STUDIO_BOOTSTRAP_ADMIN_PASSWORD=<paste-yours: pick a strong one>
STUDIO_BOOTSTRAP_ADMIN_NAME=Platform Admin


# ---------------------------------------------------------------------
# ASSET STORAGE (§9, optional — ships dormant) — Cloudinary, same one as
# conddo-backend. public_ids are prefixed studio/jobs/... so they don't
# collide with platform tenant media. Without this, asset uploads return 502.
# ---------------------------------------------------------------------
CLOUDINARY_URL=<copy-from-API: CLOUDINARY_URL>


# ---------------------------------------------------------------------
# AI ASSISTANT (optional, ships dormant) — Claude (Anthropic).
# Leave CLAUDE_API_KEY blank and AI endpoints return {available:false}
# at zero cost. To activate, paste your sk-ant-... key from
# console.anthropic.com → API keys. CLAUDE_MODEL options:
#   claude-haiku-4-5    — cheapest, fine for copy + palette
#   claude-sonnet-4-6   — balanced (default)
#   claude-opus-4-7     — max quality (most expensive)
# ---------------------------------------------------------------------
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6


# ---------------------------------------------------------------------
# SLA THRESHOLDS — defaults are fine; override only if your team's SLA
# tones (GREEN/AMBER/RED on the board) should kick in earlier/later.
# ---------------------------------------------------------------------
STUDIO_SLA_AMBER_HOURS=24
STUDIO_SLA_RED_HOURS=6


# =====================================================================
# AFTER you save the above on conddo-studio and get its public URL,
# add THESE TWO to the OTHER service (conddo-backend) → Environment.
# Without them the website change-request → Studio job hand-off stays
# dormant (PENDING records only — harmless, but the seam is off).
# =====================================================================
#
# STUDIO_BASE_URL=https://<your-conddo-studio>.onrender.com
# STUDIO_SERVICE_TOKEN=<paste the same string you generated above>
