# =====================================================================
# conddo-studio backend — Render environment variables
# =====================================================================
# How to import:
#   1. Copy this file → infra/conddo-studio.env  (gitignored — your real values)
#   2. Replace every <placeholder> with the real value
#   3. Render → conddo-studio service → Environment → "Add from .env"
#      (or use the bulk-edit / paste interface)
#   4. Paste the contents → Save → Render auto-restarts the service
#
# Placeholder markers:
#   <generate>       — pick any strong random value (Render has a Generate
#                      button on each row, or run: openssl rand -base64 48)
#   <copy-from-API>  — reuse the SAME value as on the conddo-backend service
#   <paste-yours>    — your secret / business value
# =====================================================================


# ---------------------------------------------------------------------
# DATABASE — same Postgres as conddo-backend. Studio owns the `studio`
# and `jobs` schemas (Flyway creates them at boot). Values MUST match
# what conddo-backend uses for its owner role, or you'll get
# "password authentication failed" / "permission denied to create schema".
# ---------------------------------------------------------------------
STUDIO_DB_URL=<copy-from-API: CONDDO_DB_URL>
STUDIO_DB_USER=<copy-from-API: CONDDO_DB_OWNER>
STUDIO_DB_PASSWORD=<copy-from-API: CONDDO_DB_OWNER_PASSWORD>


# ---------------------------------------------------------------------
# STUDIO JWT — internal staff auth, completely separate from the
# platform's JWT. Secret MUST be ≥ 32 bytes; HMAC-SHA256.
# Access TTL of 8h matches a working day; refresh TTL of 14d means
# staff don't get bounced to login on Monday morning.
# ---------------------------------------------------------------------
STUDIO_JWT_SECRET=<generate>
STUDIO_JWT_ISSUER=https://jobs.conddo.io
# Optional overrides (defaults shown). ISO-8601 durations.
# STUDIO_JWT_ACCESS_TTL=PT8H
# STUDIO_JWT_REFRESH_TTL=P14D


# ---------------------------------------------------------------------
# CORS — origins for the Studio frontend (separate Vercel deploy at
# conddo-studio.vercel.app — see Mickercode/conddo-studio).
#
#   STUDIO_CORS_ALLOWED_ORIGINS         — exact origins, comma-separated.
#   STUDIO_CORS_ALLOWED_ORIGIN_PATTERNS — wildcards for Vercel preview /
#                                         branch URLs. Replace `mickercode`
#                                         with your Vercel team slug if
#                                         different (check a preview URL).
# ---------------------------------------------------------------------
STUDIO_CORS_ALLOWED_ORIGINS=https://conddo-studio.vercel.app
STUDIO_CORS_ALLOWED_ORIGIN_PATTERNS=https://conddo-studio-*-mickercode.vercel.app


# ---------------------------------------------------------------------
# PLATFORM → STUDIO JOB HAND-OFF — the shared secret conddo-backend
# sends in X-Studio-Service-Token on /api/jobs/intake. Generate ONCE
# here, then paste the SAME string into conddo-backend's env (see
# bottom of file). Blank = intake disabled (always 401).
# ---------------------------------------------------------------------
STUDIO_SERVICE_TOKEN=<generate>


# ---------------------------------------------------------------------
# FIRST-ADMIN BOOTSTRAP — Studio has no public signup, so this seeds the
# first ADMIN when studio.staff is empty. Safe to leave set across restarts
# (it's a no-op once any staff row exists). After your first login, delete
# these three vars and rotate the password from the Staff page.
# Password must be ≥ 8 characters.
# ---------------------------------------------------------------------
STUDIO_BOOTSTRAP_ADMIN_EMAIL=admin@conddo.io
STUDIO_BOOTSTRAP_ADMIN_PASSWORD=<paste-yours: pick a strong one>
STUDIO_BOOTSTRAP_ADMIN_NAME=Platform Admin


# ---------------------------------------------------------------------
# ASSET STORAGE (§9, optional) — Cloudinary, same account as the platform.
# public_ids are prefixed studio/jobs/... so they don't collide with
# tenant media. Leave blank → asset uploads return 502 (the rest of the
# Studio still works fine).
# ---------------------------------------------------------------------
CLOUDINARY_URL=<copy-from-API: CLOUDINARY_URL>
# Defensive size limits — file is the per-upload cap, request is the
# multipart envelope (slightly larger), bytes is the server-side check
# enforced inside the handler. Keep all three aligned.
# STUDIO_ASSETS_MAX_FILE_SIZE=10MB
# STUDIO_ASSETS_MAX_REQUEST_SIZE=12MB
# STUDIO_ASSETS_MAX_BYTES=10485760


# ---------------------------------------------------------------------
# AI ASSISTANT (§8, optional) — Claude (Anthropic) for copy generation,
# QA scan, colour palettes. Leave CLAUDE_API_KEY blank → AI endpoints
# return {available:false} at zero cost. To activate, paste your
# sk-ant-... key from console.anthropic.com → API keys.
# Models: claude-haiku-4-5 (cheap) | claude-sonnet-4-6 (default) | claude-opus-4-7 (max).
# ---------------------------------------------------------------------
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6


# ---------------------------------------------------------------------
# SLA THRESHOLDS — hours-to-deadline that flip the board's tone.
# Defaults are fine; only override if your team's GREEN/AMBER/RED
# should kick in earlier or later.
# ---------------------------------------------------------------------
# STUDIO_SLA_AMBER_HOURS=24
# STUDIO_SLA_RED_HOURS=6
# SLA monitor cadence (§7). Defaults: first scan 60s after boot, then every
# 5 min. Auto-escalates anything past its deadline and broadcasts an
# `sla.tick` SSE snapshot of all amber/red jobs to TEAM_LEAD + ADMIN.
# STUDIO_SLA_MONITOR_INTERVAL_MS=300000
# STUDIO_SLA_MONITOR_INITIAL_DELAY_MS=60000


# ---------------------------------------------------------------------
# HIGH-PRIORITY EMAIL MIRROR (§13.4, optional) — Brevo. Mirrors three
# in-app notifications to email so staff don't miss production-critical
# updates with the Studio tab closed:
#   • Job reassigned to you
#   • QA returned your work for revision
#   • Escalation (sent to every TEAM_LEAD + ADMIN)
# Routine creates/claims/submits/approves stay SSE-only to avoid noise.
#
# Leave STUDIO_EMAIL_PROVIDER blank → LoggingStudioMailer logs what
# WOULD have been sent and returns. Set provider=brevo + api-key + from
# to actually deliver. Free tier delivers to any recipient with only a
# verified sender address.
# ---------------------------------------------------------------------
# STUDIO_EMAIL_PROVIDER=brevo
# STUDIO_EMAIL_API_KEY=<paste-yours: from app.brevo.com → SMTP & API>
# STUDIO_EMAIL_FROM=studio@conddo.io
# STUDIO_EMAIL_FROM_NAME=Conddo Studio
# STUDIO_EMAIL_BASE_URL=https://api.brevo.com


# =====================================================================
# AFTER you save the above on conddo-studio and get its public URL,
# add THESE TWO to the OTHER service (conddo-backend) → Environment.
# Without them the website change-request → Studio job hand-off stays
# dormant (PENDING records only — harmless, but the seam is off).
# =====================================================================
#
# STUDIO_BASE_URL=https://conddo-studio.onrender.com
# STUDIO_SERVICE_TOKEN=<paste the same string you generated above>
